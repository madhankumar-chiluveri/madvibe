NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT=your-deployment-name
CONVEX_SITE_URL=https://your-project.convex.site
SITE_URL=http://localhost:3000
# Optional when auth callbacks should resolve on the deployed app domain instead of *.convex.site.
CUSTOM_AUTH_SITE_URL=https://your-app.vercel.app

# Google OAuth (required for Google sign-in and account switching)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Keep CONVEX_SITE_URL aligned to the same deployment as NEXT_PUBLIC_CONVEX_URL.
# Default authorized redirect URI: https://<CONVEX_SITE_URL>/api/auth/callback/google
# If Convex uses CUSTOM_AUTH_SITE_URL=https://your-app.vercel.app, also authorize:
# https://your-app.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# News feed sync (primary: The News API, fallback: GNews)
# Feed refresh now happens on a schedule and whenever /workspace/feed opens.
THE_NEWS_API_TOKEN=your-the-news-api-token
GNEWS_API_KEY=your-gnews-api-key

# Pinterest pin generator
OPENROUTER_API_KEY=your-openrouter-api-key
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=yourtag-20
# Requires a local Python + Crawl4AI runtime with Playwright Chromium installed.
# Optional model overrides if OpenRouter changes availability.
OPENROUTER_PIN_TEXT_MODEL=google/gemma-3-27b-it:free
OPENROUTER_PIN_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b

# Ledger PIN reset email delivery
# Use a Gmail address plus an App Password from https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER=you@gmail.com
GMAIL_SMTP_APP_PASSWORD=your-16-char-app-password
GMAIL_FROM_NAME=MadVibe Security
